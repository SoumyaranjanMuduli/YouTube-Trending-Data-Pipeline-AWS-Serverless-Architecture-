{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3FullAccess",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:ListBucket",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::yt-data-pipeline-bronze-ap-south-1-dev/*",
                "arn:aws:s3:::yt-data-pipeline-bronze-ap-south-1-dev",
                "arn:aws:s3:::yt-data-pipeline-silver-ap-south-1-dev/*",
                "arn:aws:s3:::yt-data-pipeline-silver-ap-south-1-dev",
                "arn:aws:s3:::yt-data-pipeline-gold-ap-south-1-dev/*",
                "arn:aws:s3:::yt-data-pipeline-gold-ap-south-1-dev",
                "arn:aws:s3:::yt-data-pipeline-scripts-ap-south-1-dev/*",
                "arn:aws:s3:::yt-data-pipeline-scripts-ap-south-1-dev"
            ]
        }
    ]
}
